{
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./dist",

		"module": "commonjs",
		"target": "es2020",

		"esModuleInterop": true,
		"strict": true,

		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,

		"resolveJsonModule": true,
		"types": ["node"],

		"sourceMap": true
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist", "prisma"]
}
