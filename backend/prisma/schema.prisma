generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUMS
//////////////////////

enum Role {
  SUPER_ADMIN
  HR_ADMIN
  EMPLOYEE
}

enum EmploymentStatus {
  ACTIVE
  RESIGNED
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  OVERTIME
  LEAVE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}


//////////////////////
// MODELS
//////////////////////

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password      String
  role          Role

  employee      Employee?
  refreshTokens RefreshToken[]

  createdAt     DateTime @default(now())
}

model Shift {
  id            String   @id @default(uuid())
  code          String   @unique   // SHIFT-MORNING
  name          String
  startTime     String
  endTime       String
  lateTolerance Int
  isActive      Boolean  @default(true)

  employees     Employee[]
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id])

  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model Department {
  id        String     @id @default(uuid())
  code      String     @unique   // DEP-0001
  name      String
  isActive      Boolean  @default(true)

  employees Employee[]
}

model Position {
  id        String     @id @default(uuid())
  code      String     @unique   // POS-0001
  name      String
  isActive      Boolean  @default(true)

  employees Employee[]
}

model Employee {
  id           String   @id @default(uuid())
  code         String   @unique   // EMP-0001

  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])

  salary       Float
  status       EmploymentStatus

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  positionId   String
  position     Position   @relation(fields: [positionId], references: [id])

  shiftId      String
  shift        Shift      @relation(fields: [shiftId], references: [id])

  attendances  Attendance[]
  leaves       Leave[]
  payrolls     Payroll[]

  createdAt    DateTime @default(now())
}

model Attendance {
  id              String   @id @default(uuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id])
  
  date            DateTime
  clockIn         DateTime? 
  clockOut        DateTime? 
  lateMinutes     Int       @default(0)
  overtimeMinutes Int       @default(0)
  isOvertime      Boolean   @default(false)
  status          AttendanceStatus
  
  leaveId         String?   
  leave           Leave?    @relation(fields: [leaveId], references: [id])

  // ==========================================
  // 🔥 FITUR 4: GEOFENCING & BIOMETRIC
  // ==========================================
  clockInLat      Float?    // Latitude saat absen masuk
  clockInLng      Float?    // Longitude saat absen masuk
  clockInPhoto    String?   // URL foto selfie absen masuk
  clockOutLat     Float?    
  clockOutLng     Float?    
  clockOutPhoto   String?   

  // ==========================================
  // 🔥 FITUR 1 & 2: AUTOMATION FLAGS
  // ==========================================
  isAutoClockOut  Boolean   @default(false) // True jika sistem yang memulangkan paksa
  isAutoAbsent    Boolean   @default(false) // True jika sistem yang meng-alphakan
  notes           String?   @db.Text        // Catatan sistem: "Auto absent by system at 23:55"

  createdAt       DateTime  @default(now())
}

model Leave {
  id          String      @id @default(uuid())
  code        String      @unique
  employeeId  String
  employee    Employee    @relation(fields: [employeeId], references: [id])
  type        String      
  startDate   DateTime
  endDate     DateTime
  reason      String      @db.Text
  status      LeaveStatus @default(PENDING)
  approvedBy  String?     
  createdAt   DateTime    @default(now())

  attendances Attendance[] // 🔥 Relasi balik dari Attendance
}

model Payroll {
  id              String   @id @default(uuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id])

  month           Int
  year            Int

  baseSalary      Float
  totalAttendance Int
  totalLate       Int
  totalAbsent     Int

  overtimePay     Float
  deductions      Float

  totalSalary     Float

  createdAt       DateTime @default(now())

  @@unique([employeeId, month, year]) // 🔥 penting
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String

  createdAt DateTime @default(now())
}

model Setting {
  id          String   @id @default(uuid())
  key         String   @unique // Contoh: "OFFICE_LAT", "OFFICE_LNG", "LATE_PENALTY_PER_MINUTE", "MAX_GEOFENCE_RADIUS"
  value       String   @db.Text // Disimpan dalam bentuk string/JSON string
  description String?  // Penjelasan untuk HR (misal: "Latitude titik tengah kantor")
  
  updatedAt   DateTime @updatedAt
}

model PayrollComponent {
  id          String   @id @default(uuid())
  name        String   // Contoh: "Tunjangan Transport", "Denda Telat", "BPJS"
  type        String   // "EARNING" (Pendapatan) atau "DEDUCTION" (Potongan)
  isDefault   Boolean  @default(false) // Jika true, otomatis berlaku untuk semua karyawan
  amount      Float    // Nominal tetap (Bisa juga diset 0 jika angkanya dinamis dari perhitungan absen)
  
  createdAt   DateTime @default(now())
}